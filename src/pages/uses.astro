---
import Base from '../layouts/Base.astro';
import { parse } from 'yaml';
import usesRaw from '../../data/uses.yaml?raw';

const usesData = parse(usesRaw) as any[];

const badgeStyle: Record<string, string> = {
  'favourite':   'background:var(--accent2);color:#fff;',
  'free':        'background:var(--paper3);color:var(--ink3);',
  'open source': 'background:#ede9fe;color:#5b21b6;',
};
---

<Base title="/uses — Alexander (Thê) Quach">

<div style="max-width:820px;margin:0 auto;padding:7rem 2.5rem 6rem;">

  <header class="reveal" style="margin-bottom:4rem;padding-bottom:2.5rem;border-bottom:1.5px solid var(--paper3);">
    <p style="font-family:var(--mono);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent2);margin-bottom:1rem;">Setup · Stack · Tools</p>
    <h1 style="font-family:var(--serif);font-size:clamp(2.8rem,6vw,4.5rem);font-weight:400;line-height:1.05;color:var(--accent);margin-bottom:1.25rem;">
      What I <em style="font-style:italic;color:var(--accent2);">use</em>
    </h1>
    <p style="font-size:1rem;color:var(--ink2);max-width:52ch;line-height:1.75;">
      The hardware, software, and tools in my daily workflow. Listed on <a href="https://uses.tech" target="_blank" style="color:var(--accent2);text-underline-offset:3px;">uses.tech</a>. Last updated 2025.
    </p>
  </header>

  {usesData.map((section: any) => (
    <div class="reveal" style="margin-bottom:3.5rem;">
      <div style="display:flex;align-items:center;gap:.9rem;margin-bottom:1.25rem;">
        <div style="width:34px;height:34px;background:var(--accent);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;">
          {section.icon}
        </div>
        <h2 style="font-family:var(--serif);font-size:1.55rem;font-weight:400;color:var(--accent);">{section.section}</h2>
      </div>

      {section.specCards && section.specCards.map((card: any, i: number) => (
        <div style={`background:var(--accent);border-radius:${i === 0 ? '4px 4px 0 0' : i === section.specCards.length - 1 ? '0 0 4px 4px' : '0'};padding:1.4rem 1.65rem;margin-bottom:1px;color:#fff;`}>
          <div style="font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.5rem;">{card.label}</div>
          <div style="font-family:var(--serif);font-size:1.3rem;color:#fff;margin-bottom:.9rem;">{card.name}</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:.35rem .75rem;">
            {Object.entries(card.specs).map(([k, v]) => (
              <div style="display:flex;gap:.5rem;font-size:.82rem;">
                <span style="font-family:var(--mono);font-size:.75rem;color:rgba(255,255,255,.38);flex-shrink:0;min-width:55px;">{k}</span>
                <span style="color:rgba(255,255,255,.82);">{v as string}</span>
              </div>
            ))}
          </div>
        </div>
      ))}

      {section.items && (
        <div style={`display:flex;flex-direction:column;border:1.5px solid var(--paper3);border-radius:4px;overflow:hidden;${section.specCards ? 'margin-top:1.25rem;' : ''}`}>
          {section.items.map((item: any, i: number) => (
            <div style={`display:grid;grid-template-columns:210px 1fr;gap:1.5rem;align-items:start;padding:1.05rem 1.35rem;background:var(--paper);${i < section.items.length - 1 ? 'border-bottom:1px solid var(--paper3);' : ''}`}>
              <div style="display:flex;flex-direction:column;gap:.2rem;">
                <span style="font-weight:500;font-size:.92rem;color:var(--ink);line-height:1.3;">{item.title}</span>
                <span style="font-family:var(--mono);font-size:10px;letter-spacing:.07em;color:var(--accent2);text-transform:uppercase;">{item.sub}</span>
                {item.badge && (
                  <span style={`display:inline-block;margin-top:.15rem;font-family:var(--mono);font-size:9px;letter-spacing:.08em;padding:.14rem .48rem;border-radius:2px;text-transform:uppercase;width:fit-content;${badgeStyle[item.badge] ?? ''}`}>
                    {item.badge}
                  </span>
                )}
              </div>
              <div style="font-size:.875rem;color:var(--ink2);line-height:1.65;">{item.description}</div>
            </div>
          ))}
        </div>
      )}
    </div>
  ))}

</div>

</Base>

<style>
  @media (max-width: 700px) {
    div[style*="grid-template-columns:210px"] { grid-template-columns: 1fr !important; gap: .35rem !important; }
    div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>
