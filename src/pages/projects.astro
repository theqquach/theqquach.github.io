---
import Base from '../layouts/Base.astro';
import { parse } from 'yaml';
import projectsRaw from '../../data/personal-projects.yaml?raw';

const projects = parse(projectsRaw) as any[];

const statusStyle: Record<string, string> = {
  'complete':      'background:#00ab7a;color:#0f4f3d;',
  'in progress':   'background:#fef3c7;color:#92400e;',
  'working paper': 'background:#ede9fe;color:#5b21b6;',
};

const tagColor = (tag: string) => {
  const map: Record<string, string> = {
    'Economics':        '#3b1f6e',
    'Statistics':       '#7c3aed',
    'Python':           '#0891b2',
    'R':                '#2563eb',
    'Policy':           '#047857',
    'Finance':          '#b45309',
    'Machine Learning': '#fa28fa',
    'Computer Vision':  '#001494',
    'PyTorch':          '#ff8614',
  };
  return map[tag] ?? '#6b7280';
};
---

<Base title="Projects — Alexander (Thê) Quach">

<div style="max-width:900px;margin:0 auto;padding:7rem 2.5rem 6rem;">

  <!-- HEADER -->
  <header class="reveal" style="margin-bottom:4rem;padding-bottom:2.5rem;border-bottom:1.5px solid var(--paper3);">
    <p style="font-family:var(--mono);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent2);margin-bottom:1rem;">Research & Analysis</p>
    <h1 style="font-family:var(--serif);font-size:clamp(2.8rem,6vw,4.5rem);font-weight:400;line-height:1.05;color:var(--accent);margin-bottom:1.25rem;">
      Personal <em style="font-style:italic;color:var(--accent2);">projects</em>
    </h1>
    <p style="font-size:1rem;color:var(--ink2);max-width:56ch;line-height:1.75;">
      Standalone research and analysis projects — each with a full written report. Click any project to read the full analysis.
    </p>
  </header>

  <!-- PROJECT GRID -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:1.5px;border:1.5px solid var(--paper3);">
    {projects.map((p: any) => (
      <div class="proj-card" style="background:var(--paper);border:1.5px solid var(--paper3);margin:-1px;display:flex;flex-direction:column;">

        <!-- Top bar with status -->
        <div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem 0;">
          <div style="display:flex;gap:.4rem;flex-wrap:wrap;">
            {p.tags.map((tag: string) => (
              <span style={`font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:.2rem .55rem;border-radius:2px;color:#fff;background:${tagColor(tag)};`}>
                {tag}
              </span>
            ))}
          </div>
          <span style={`font-family:var(--mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;padding:.2rem .6rem;border-radius:2px;flex-shrink:0;${statusStyle[p.status] ?? ''}`}>
            {p.status}
          </span>
        </div>

        <!-- Content -->
        <div style="padding:1rem 1.5rem 1.5rem;flex:1;display:flex;flex-direction:column;">
          <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;margin-bottom:.6rem;">
            <h2 style="font-family:var(--serif);font-size:1.4rem;font-weight:400;color:var(--accent);line-height:1.2;">{p.title}</h2>
            <span style="font-family:var(--mono);font-size:11px;color:var(--ink3);flex-shrink:0;">{p.date}</span>
          </div>

          <p style="font-size:.9rem;color:var(--ink2);line-height:1.7;flex:1;margin-bottom:1.25rem;">{p.description}</p>

          <!-- Methods -->
          {p.methods && (
            <div style="margin-bottom:1.25rem;">
              <p style="font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);margin-bottom:.5rem;">Methods</p>
              <div style="display:flex;flex-wrap:wrap;gap:.35rem;">
                {p.methods.map((m: string) => (
                  <span style="font-size:.8rem;padding:.22rem .6rem;border:1px solid var(--paper3);border-radius:2px;color:var(--ink2);background:var(--paper2);">
                    {m}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Links -->
          <div style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap;margin-top:auto;padding-top:1rem;border-top:1px solid var(--paper3);">
            {p.report && (
              <a
                href={`/projects/${p.slug}/`}
                style="display:inline-flex;align-items:center;gap:.4rem;font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;background:var(--accent2);color:#fff;padding:.5rem 1rem;border-radius:2px;transition:background .18s;"
                onmouseenter="this.style.background='var(--accent)'"
                onmouseleave="this.style.background='var(--accent2)'"
              >
                Read report →
              </a>
            )}
            {p.pdf && (
              <a
                href={p.pdf}
                download
                style="display:inline-flex;align-items:center;gap:.4rem;font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;background:var(--paper2);color:var(--ink2);padding:.5rem 1rem;border-radius:2px;border:1px solid var(--paper3);transition:all .18s;"
                onmouseenter="this.style.background='var(--paper3)';this.style.color='var(--ink)'"
                onmouseleave="this.style.background='var(--paper2)';this.style.color='var(--ink2)'"
              >
                ↓ PDF
              </a>
            )}
            {p.github && (
              <a
                href={p.github}
                target="_blank"
                style="font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;color:var(--ink3);border-bottom:1px solid transparent;transition:all .18s;"
                onmouseenter="this.style.color='var(--accent2)';this.style.borderColor='var(--accent2)'"
                onmouseleave="this.style.color='var(--ink3)';this.style.borderColor='transparent'"
              >
                GitHub →
              </a>
            )}
          </div>
        </div>
      </div>
    ))}

    <!-- COMING SOON placeholder — remove once you have more projects -->
    <div style="background:var(--paper2);border:1.5px dashed var(--paper3);margin:-1px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:3rem;min-height:260px;text-align:center;">
      <p style="font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);margin-bottom:.5rem;">More coming</p>
      <p style="font-size:.875rem;color:var(--ink3);max-width:24ch;line-height:1.6;">New projects added as they're completed.</p>
    </div>

  </div>
</div>

</Base>

<style>
  .proj-card { transition: background .18s; }
  .proj-card:hover { background: #fff !important; }

  @media (max-width: 700px) {
    div[style*="auto-fill,minmax(380px"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
